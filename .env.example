# Local development environment. Copy to .env and adjust as needed.

# Postgres
POSTGRES_USER=tms
POSTGRES_PASSWORD=tms_dev_password
POSTGRES_DB=tms

# JWT signing — DO NOT use this value in any non-local environment
JWT_SIGNING_KEY=local-dev-key-change-me-please-at-least-32-bytes

# Kafka
KAFKA_BOOTSTRAP=localhost:9092

# Object storage (MinIO local emulating S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DOCUMENTS=tms-documents

# Anthropic API (rate-confirmation extraction)
ANTHROPIC_API_KEY=
